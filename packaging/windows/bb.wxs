<?xml version="1.0" encoding="utf-8"?>
<!-- WiX source for the Windows MSI installer, built with wixl (msitools) by
     packaging/windows/build-msi.sh. The version is passed in via -D Version=...
     and bb.exe must sit in wixl's working directory. -->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product Name="bb (Bitbucket CLI)"
           Id="*"
           UpgradeCode="5b6b89e0-9ff0-4d11-ab25-56c726fc1cd2"
           Language="1033"
           Codepage="1252"
           Version="$(var.Version)"
           Manufacturer="delabrcd">
    <Package Id="*"
             Keywords="Installer"
             Description="bb - the Bitbucket command line interface"
             Manufacturer="delabrcd"
             InstallerVersion="200"
             Languages="1033"
             Compressed="yes"
             SummaryCodepage="1252"/>
    <Media Id="1" Cabinet="bb.cab" EmbedCab="yes"/>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLDIR" Name="bb">
          <!-- No <Environment> PATH entry: the wixl (msitools) build used in CI
               does not support it. Installs to Program Files\bb; add it to PATH
               manually, or use the portable zip. -->
          <Component Id="MainExecutable" Guid="3f1a264b-8017-44d0-a944-79412a26634e">
            <File Id="bbexe" Name="bb.exe" Source="bb.exe" KeyPath="yes"/>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="Complete" Level="1">
      <ComponentRef Id="MainExecutable"/>
    </Feature>
  </Product>
</Wix>
